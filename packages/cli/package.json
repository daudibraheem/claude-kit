    "github-actions",
    "migration",
    "code-review",
    "changelog",
    "release",
    "audit",
    "security",
    "doctor",
    "diagnostics"
  ],
  "license": "MIT",
  "author": "Daud Ibraheem Saleem",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daudibraheem/claude-scout.git"
  },
  "homepage": "https://github.com/daudibraheem/claude-scout#readme",
  "bugs": {
    "url": "https://github.com/daudibraheem/claude-scout/issues"
  },
