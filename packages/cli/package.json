{
  "name": "claude-scout",
  "version": "0.3.0",
  "description": "Project-aware CLI for Claude Code: generate .claude/ config, ONBOARDING.md + setup.sh, GitHub Actions workflows, ORM-aware migrations, commit messages, PR descriptions, and test scaffolds — all grounded in your real repo.",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "config",
    "config-generator",
    "onboarding",
    "developer-onboarding",
    "scaffold",
    "cli",
    "developer-tools",
    "git-hooks",
    "commit-message",
    "pr-description",
    "test-scaffold",
    "github-actions",
    "migration"
  ],
  "license": "MIT",
  "author": "Daud Ibraheem Saleem",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daudibraheem/claude-scout.git"
  },
  "homepage": "https://github.com/daudibraheem/claude-scout#readme",
  "bugs": {
    "url": "https://github.com/daudibraheem/claude-scout/issues"
  },
  "type": "module",
  "bin": {
    "claude-scout": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "cd ../.. && pnpm -r build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "chalk": "^5.3.0",
