  "devDependencies": {
    "@claude-scout/ai-generator": "workspace:*",
    "@claude-scout/core": "workspace:*",
    "@claude-scout/detectors": "workspace:*",
    "@claude-scout/templates": "workspace:*",
    "@types/inquirer": "^9.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0"
  }
}
